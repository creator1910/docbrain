# Supabase — copy from your project's API settings
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Service role key — NEVER expose to client
# Used only in server-side admin operations (account deletion)
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>

# Site URL — used for OAuth/email auth redirect callbacks
# Local: http://localhost:3000 | Production: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Anthropic — for document extraction
# https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=<anthropic-api-key>
